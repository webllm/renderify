{
  "$schema": "https://biomejs.dev/schemas/2.5.3/schema.json",
  "files": {
    "includes": [
      "**",
      "!**/node_modules",
      "!**/.next",
      "!**/.source",
      "!**/out",
      "!**/dist",
      "!**/dist-types",
      "!.artifacts",
      "!.pnpm-store",
      "!.turbo",
      "!.renderify",
      "!.claude",
      "!openui"
    ]
  },
  "linter": {
    "enabled": true,
    "rules": {
      "preset": "recommended",
      "suspicious": {
        "noUndeclaredEnvVars": {
          "level": "on",
          "options": {
            "allowedEnvVars": [
              // Runtime configuration remains dynamic in built packages and CLI commands.
              "PORT",
              // Official Codex CLI home directory, reused for local `code cli` auth.
              "CODEX_HOME",
              // Standard proxy variables honored for outbound CLI requests.
              "HTTPS_PROXY",
              "https_proxy",
              "HTTP_PROXY",
              "http_proxy",
              "ALL_PROXY",
              "all_proxy",
              "RENDERIFY_CODEX_.*",
              "RENDERIFY_HOME",
              "RENDERIFY_JSPM_CDN_URL",
              "RENDERIFY_LLM_.*",
              "RENDERIFY_PLAYGROUND_.*",
              "RENDERIFY_RUNTIME_.*",
              "RENDERIFY_SECURITY_PROFILE",
              "RENDERIFY_STRICT_SECURITY",
              "RENDERIFY_SITE_BASE_PATH",
              "NEXT_PUBLIC_RENDERIFY_BASE_PATH",
              // Direct scripts and uncached tasks do not contribute these values to Turbo outputs.
              "GITHUB_BASE_REF",
              "GITHUB_STEP_SUMMARY",
              "RELEASE_TAG",
              "RENDERIFY_BENCH_.*",
              "RENDERIFY_CHANGESET_.*",
              "npm_config_user_agent"
            ]
          }
        }
      }
    }
  },
  "formatter": {
    "enabled": true,
    "indentStyle": "space",
    "indentWidth": 2
  }
}
