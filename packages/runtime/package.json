{
  "name": "@renderify/runtime",
  "version": "0.8.1",
  "main": "dist/runtime.cjs",
  "types": "dist/runtime.d.ts",
  "module": "dist/runtime.mjs",
  "exports": {
    ".": {
      "types": "./dist/runtime.d.ts",
      "import": "./dist/runtime.mjs",
      "require": "./dist/runtime.cjs",
      "default": "./dist/runtime.mjs"
    },
    "./package.json": "./package.json"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "test": "echo \"Error: no test specified\" && exit 1",
    "typecheck": "tsc -p tsconfig.json --pretty false --noEmit",
    "lint": "biome lint src",
    "clean": "node -e \"for (const dir of ['dist', 'dist-types']) require('node:fs').rmSync(dir, { recursive: true, force: true })\"",
    "build:repo": "tsup --config tsup.config.ts",
    "watch:repo": "tsup --config tsup.config.ts --watch"
  },
  "author": "unadlib",
  "license": "MIT",
  "description": "A runtime for Renderify",
  "keywords": [
    "renderify",
    "runtime",
    "jspm",
    "llm",
    "preact",
    "ui-runtime"
  ],
  "homepage": "https://github.com/webllm/renderify#readme",
  "bugs": {
    "url": "https://github.com/webllm/renderify/issues"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/webllm/renderify.git",
    "directory": "packages/runtime"
  },
  "engines": {
    "node": ">=22.0.0"
  },
  "publishConfig": {
    "access": "public",
    "provenance": true
  },
  "sideEffects": false,
  "dependencies": {
    "@renderify/ir": "workspace:^",
    "@renderify/security": "workspace:^",
    "esbuild": "^0.28.1",
    "preact": "^10.29.7",
    "preact-render-to-string": "^6.7.0"
  }
}
